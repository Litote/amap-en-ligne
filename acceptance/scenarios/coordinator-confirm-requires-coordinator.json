{
  "id": "coordinator-confirm-requires-coordinator",
  "title": "Confirming a delivery whose contract has no coordinator is rejected with MISSING_COORDINATOR",
  "targets": ["coordinator-flow", "flutter"],
  "given": {
    "backendState": "organization:org-1 with a future PLANNED delivery:delivery-1 containing one DeliveryContract:contract-1 with an empty coordinators list; member:admin-1 authorized on organization:org-1 with role ADMIN",
    "appState": "fresh organization cache synchronized from bootstrap"
  },
  "when": [
    {
      "actor": "admin",
      "action": "sync",
      "request": {
        "cursors": {
          "organization:org-1": null
        },
        "mutations": [
          {
            "client_op_id": "op-confirm",
            "op": {
              "type": "Upsert",
              "payload": {
                "type": "Organization",
                "organization": {
                  "organization_id": "org-1",
                  "name": "AMAP des Collines",
                  "contact_email": "contact@amap.example.com",
                  "active_status": true,
                  "timezone": "Europe/Paris",
                  "default_language": "fr",
                  "created_instant": "2025-01-01T00:00:00Z",
                  "last_updated_instant": "2025-01-01T00:00:00Z",
                  "producers": [],
                  "products": [],
                  "deliveries": [
                    {
                      "delivery_id": "delivery-1",
                      "organization_id": "org-1",
                      "scheduled_date": "2099-06-15T18:00:00",
                      "status": "CONFIRMED",
                      "min_volunteers_required": 2,
                      "contracts": [
                        {
                          "contract_id": "contract-1",
                          "coordinators": [],
                          "basket_quantity": 10,
                          "delivery_description": "Weekly basket",
                          "status": "PENDING",
                          "slots": []
                        }
                      ]
                    }
                  ]
                }
              }
            }
          }
        ]
      }
    }
  ],
  "then": {
    "lastResponse": {
      "statusCode": 200,
      "mutationOutcomes": [
        {
          "clientOpId": "op-confirm",
          "status": "REJECTED",
          "error": {
            "code": "MISSING_COORDINATOR"
          }
        }
      ]
    }
  }
}
