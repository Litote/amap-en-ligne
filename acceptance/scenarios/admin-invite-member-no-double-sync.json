{
  "id": "admin-invite-member-no-double-sync",
  "title": "Inviting a member triggers exactly one sync even when UserManagementBloc and SyncBloc race",
  "targets": ["flutter"],
  "given": {
    "backendState": "organization exists and caller is authorized on its sync scope",
    "appState": "fresh organization cache with one pending member invitation mutation"
  },
  "when": [
    {
      "actor": "client",
      "action": "sync (only once despite two concurrent callers)",
      "request": {
        "cursors": {
          "organization:org-1": "c0"
        },
        "mutations": [
          {
            "client_op_id": "op-invite",
            "op": {
              "type": "Upsert",
              "payload": {
                "type": "MemberInvitation",
                "memberInvitation": {
                  "invitation_id": "tmp_inv",
                  "organization_id": "org-1",
                  "email": "alice@example.org",
                  "first_name": "Alice",
                  "last_name": "Martin",
                  "roles": ["VOLUNTEER"],
                  "status": "PENDING_ACTIVATION",
                  "created_at": "2026-01-01T00:00:00Z",
                  "expires_at": "2026-01-08T00:00:00Z"
                }
              }
            }
          }
        ]
      }
    }
  ],
  "then": {
    "lastResponse": {
      "mutationOutcomes": [
        {
          "clientOpId": "op-invite",
          "status": "APPLIED",
          "serverEntityId": "inv-real-1"
        }
      ]
    }
  }
}
