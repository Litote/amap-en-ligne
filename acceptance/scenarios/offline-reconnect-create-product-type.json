{
  "id": "offline-reconnect-create-product-type",
  "title": "A product type created offline stays queued until reconnect, then converges to the server id",
  "targets": ["flutter"],
  "given": {
    "backendState": "empty",
    "appState": "fresh"
  },
  "when": [
    {
      "actor": "client",
      "action": "sync",
      "request": {
        "cursors": {},
        "mutations": []
      }
    },
    {
      "actor": "client",
      "action": "sync",
      "request": {
        "cursors": {
          "ProductType": "previous-bootstrap-cursor"
        },
        "mutations": [
          {
            "client_op_id": "op-1",
            "op": {
              "type": "Upsert",
              "payload": {
                "type": "ProductType",
                "productType": {
                  "product_type_id": "tmp_entity-1",
                  "producer_account_id": "producer-1",
                  "name": "Vegetables",
                  "supported_basket_sizes": [
                    {
                      "name": "small"
                    }
                  ]
                }
              }
            }
          }
        ]
      }
    }
  ],
  "then": {}
}
