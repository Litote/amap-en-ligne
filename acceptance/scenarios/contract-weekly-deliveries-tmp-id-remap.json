{
  "id": "contract-weekly-deliveries-tmp-id-remap",
  "title": "Batch with tmp_ Contract upsert + Organization upsert linking the same tmp_ contract id: back allocates a real id for the contract and rewrites the delivery link atomically",
  "targets": ["contract-lifecycle"],
  "given": {
    "backendState": "organization:org-1 with an ended contract:contract-1 (season 2020); member:admin-1 with role ADMIN",
    "appState": "fresh organization cache synchronized from bootstrap"
  },
  "when": [
    {
      "actor": "admin",
      "action": "sync",
      "request": {
        "cursors": {
          "organization:org-1": null
        },
        "mutations": [
          {
            "client_op_id": "op-create-contract",
            "op": {
              "type": "Upsert",
              "payload": {
                "type": "Contract",
                "contract": {
                  "contract_id": "tmp_contract_weekly",
                  "name": "Saison hebdo 2027",
                  "organization_id": "org-1",
                  "producer_account_id": "producer-1",
                  "min_delivery_date": "2027-01-01",
                  "max_delivery_date": "2027-12-31",
                  "delivery_count": 52,
                  "season_year": 2027,
                  "status": "IN_PREPARATION",
                  "product_prices": [
                    {
                      "product_type_id": "pt-tomato"
                    }
                  ],
                  "coordinators": [],
                  "members": []
                }
              }
            }
          },
          {
            "client_op_id": "op-create-org-with-delivery",
            "op": {
              "type": "Upsert",
              "payload": {
                "type": "Organization",
                "organization": {
                  "organization_id": "org-1",
                  "name": "Test Organization",
                  "contact_email": "test@example.com",
                  "active_status": true,
                  "timezone": "Europe/Paris",
                  "default_language": "fr",
                  "created_instant": "2025-01-01T00:00:00Z",
                  "last_updated_instant": "2025-01-01T00:00:00Z",
                  "producers": [],
                  "products": [],
                  "deliveries": [
                    {
                      "delivery_id": "delivery-weekly-1",
                      "organization_id": "org-1",
                      "scheduled_date": "2027-01-07T18:00:00",
                      "status": "PLANNED",
                      "min_volunteers_required": 1,
                      "contracts": [
                        {
                          "contract_id": "tmp_contract_weekly",
                          "basket_quantity": 0,
                          "delivery_description": "Saison hebdo 2027",
                          "status": "PENDING",
                          "coordinators": []
                        }
                      ]
                    }
                  ]
                }
              }
            }
          }
        ]
      }
    }
  ],
  "then": {
    "lastResponse": {
      "statusCode": 200,
      "mutationOutcomes": [
        {
          "clientOpId": "op-create-contract",
          "status": "APPLIED",
          "serverEntityId": {
            "kind": "present-and-not-equal",
            "value": "tmp_contract_weekly"
          }
        },
        {
          "clientOpId": "op-create-org-with-delivery",
          "status": "APPLIED"
        }
      ]
    }
  }
}
