{
  "id": "volunteer-register-other-forbidden",
  "title": "A volunteer cannot register another member to a slot — mutation is rejected with FORBIDDEN",
  "targets": ["volunteer-flow", "flutter"],
  "given": {
    "backendState": "organization:org-1 with a future CONFIRMED delivery:delivery-1 containing a STANDARD slot with capacity 2 and no registrations; member:volunteer-1 authorized on organization:org-1 with role VOLUNTEER; member:other-member exists in the same organization",
    "appState": "fresh organization cache synchronized from bootstrap"
  },
  "when": [
    {
      "actor": "volunteer",
      "action": "sync",
      "request": {
        "cursors": {
          "organization:org-1": null
        },
        "mutations": [
          {
            "client_op_id": "op-register-other",
            "op": {
              "type": "Upsert",
              "payload": {
                "type": "Organization",
                "organization": {
                  "organization_id": "org-1",
                  "name": "AMAP des Collines",
                  "contact_email": "contact@amap.example.com",
                  "active_status": true,
                  "timezone": "Europe/Paris",
                  "default_language": "fr",
                  "created_instant": "2025-01-01T00:00:00Z",
                  "last_updated_instant": "2025-01-01T00:00:00Z",
                  "producers": [],
                  "products": [],
                  "deliveries": [
                    {
                      "delivery_id": "delivery-1",
                      "organization_id": "org-1",
                      "scheduled_date": "2099-06-15T18:00:00",
                      "status": "CONFIRMED",
                      "min_volunteers_required": 2,
                      "contracts": [
                        {
                          "contract_id": "contract-1",
                          "coordinators": ["coordinator-1"],
                          "basket_quantity": 10,
                          "delivery_description": "Weekly basket",
                          "status": "PENDING",
                          "slots": [
                            {
                              "start_time": "2099-06-15T18:00:00",
                              "end_time": "2099-06-15T20:00:00",
                              "activity_type": "RECEPTION",
                              "required_volunteers": 2,
                              "current_registrations": 1,
                              "status": "OPEN",
                              "slot_kind": "STANDARD",
                              "registrations": [
                                {
                                  "member_id": "other-member",
                                  "display_name": "Other Member",
                                  "member_email": "other@example.com",
                                  "registration_instant": "2099-06-01T10:00:00Z",
                                  "status": "REGISTERED"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              }
            }
          }
        ]
      }
    }
  ],
  "then": {
    "lastResponse": {
      "statusCode": 200,
      "mutationOutcomes": [
        {
          "clientOpId": "op-register-other",
          "status": "REJECTED"
        }
      ]
    }
  }
}
