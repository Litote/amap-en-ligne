# Local-dev environment for `:deploy:jvm:run`.
#
# Copy to `.env` (gitignored) and the Gradle `run` task will load these
# variables automatically:
#
#   cp back/deploy/jvm/.env.example back/deploy/jvm/.env
#   ./gradlew :deploy:jvm:run
#
# The values below match the dev defaults in `docker-compose.yml` so a
# stack started with `docker compose up -d` works out of the box.
# Never reuse these values outside local development.

# --- GoTrue (Supabase Auth) — mandatory, no defaults in code ---
GOTRUE_JWT_SECRET=dev-jwt-secret-change-me-dev-jwt-secret-change-me
GOTRUE_JWT_ISSUER=http://localhost:9999

# Optional — defaults to `authenticated` (GoTrue's default `aud`).
# GOTRUE_JWT_AUDIENCE=authenticated

# --- Postgres — optional, the persistence module already has these defaults ---
# POSTGRES_URL=jdbc:postgresql://localhost:5432/postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# --- SMTP (MailHog for local dev — matches docker-compose.yml defaults) ---
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_FROM_EMAIL=noreply@amap-en-ligne.fr
# SMTP_TLS=false
# SMTP_USERNAME=
# SMTP_PASSWORD=

# --- Activation email cron interval (milliseconds) ---
# ACTIVATION_EMAIL_INTERVAL_MS=60000

# --- GoTrue service role (required for admin user creation at activation) ---
# This JWT must be signed with GOTRUE_JWT_SECRET using role=service_role claim.
# The value below is pre-generated for the dev secret above (dev-jwt-secret-change-me-dev-jwt-secret-change-me).
# Generate a fresh one with: ./gradlew :deploy:jvm:generateServiceRoleToken
# Never reuse this outside local development.
GOTRUE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoiaHR0cDovL2xvY2FsaG9zdDo5OTk5IiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjk5OTk5OTk5OTl9.L7h67Jr426JJFjrl3qMvH4nYh6ooMYa7LaFVE8IQ9sU


INSTANCE_NAME=dev
INSTANCE_API_URL=http://localhost:8080
# --- Web app base URL (used in activation emails; defaults to INSTANCE_API_URL) ---
# INSTANCE_WEB_URL=http://localhost:5000

# --- Instance customization ---
# URL of the terms-of-service page, exposed in GET /.well-known/amap-en-ligne.json
# as `terms_url` and linked from the app's registration flows.
# When unset the app falls back to <web-root>/cgu.html (the file served by nginx
# or CloudFront from infra/instance/cgu.html).
# INSTANCE_TERMS_URL=https://votre-amap.fr/cgu.html

# --- Misc ---
# PORT=8080
# KOIN_LOG_LEVEL=INFO

# ── Cross-component test variables ──────────────────────────────────────────
# Used by `./gradlew frontCrossComponentTest` (and `crossComponentTest` /
# `allAcceptanceTests`).  BACK_URL and GOTRUE_URL are inferred automatically
# from INSTANCE_API_URL and GOTRUE_JWT_ISSUER above when not set explicitly.
# Tests that are missing their required variables are skipped individually.
#
# BEARER_TOKEN=<valid access token for an ADMIN user on the local dev instance>
# ORGANIZATION_ID=<id of the test organization>
# TEST_EMAIL=<email of a regular member account used for auth/sync tests>
# TEST_PASSWORD=<password for TEST_EMAIL>
# NEW_PASSWORD=<password used after a password-reset test (must differ from TEST_PASSWORD)>
# ADMIN_EMAIL=<email of the ADMIN account (used for invitation / request tests)>
# NO_ACCOUNT_NAME=<display name for the no-account producer created in lifecycle tests>
# NO_ACCOUNT_EMAIL=<contact email for that producer (must be unique per test run)>
# PRODUCER_ACCOUNT_ID=<id of an existing ACCOUNT_BACKED producer in the test org>
# PRODUCER_NAME=<name of that producer>
# REQUESTER_EMAIL=<email used to submit a producer or member join request>

# --- CORS — only needed when the web client is served from a different origin ---
# Unset / empty (default in production same-origin deploy) → Ktor CORS plugin not installed.
# `*` → anyHost(). Convenient for dev; never use in production.
# CSV of explicit origins (https://app.example,https://catalog.example) → whitelist mode.
# Note: the Lambda deployment handles CORS at API Gateway, not here.
# CORS_ALLOW_ORIGINS=*
